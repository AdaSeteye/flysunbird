ENV=local
APP_NAME=FlySunbird API
SECRET_KEY=change_me_super_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+psycopg2://flysunbird:flysunbird@db:5432/flysunbird
REDIS_URL=redis://redis:6379/0

# --- Email (choose one: SendGrid OR SMTP) ---
# Option A: SendGrid (recommended for production). If set, SMTP is ignored.
# Get API key from https://app.sendgrid.com/ → Settings → API Keys. Verify sender in SendGrid.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Option B: SMTP (Gmail, Office 365, or your mail server). Used when SENDGRID_API_KEY is empty.
# Gmail: use App Password (2FA required). Host=smtp.gmail.com Port=587
# Office 365: smtp.office365.com Port=587
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ops@flysunbird.local

CLIENT_BASE_URL=http://localhost:8000
API_PUBLIC_URL=http://localhost:8000

TICKET_LOCAL_DIR=./data/tickets
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# Selcom (Tanzania: mobile money, cards). Vendor = Till Number from Selcom.
# Ensure your server IP is whitelisted: https://paypoint.selcommobile.com/getip.php
SELCOM_BASE_URL=https://apigw.selcommobile.com/v1
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=
